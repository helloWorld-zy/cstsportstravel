{
  "name": "旅游预订平台",
  "appid": "",
  "description": "旅游预订平台 - 支持境内/出境跟团游",
  "versionName": "0.2.0",
  "versionCode": "200",
  "transformPx": false,
  "mp-weixin": {
    "appid": "",
    "setting": {
      "urlCheck": true,
      "es6": true,
      "postcss": true,
      "minified": true,
      "newFeature": true
    },
    "usingComponents": true,
    "permission": {
      "scope.userLocation": {
        "desc": "获取位置用于推荐附近出发地"
      }
    },
    "requiredPrivateInfos": [
      "chooseAddress",
      "getPhoneNumber"
    ]
  },
  "mp-toutiao": {
    "appid": "",
    "setting": {
      "urlCheck": true,
      "es6": true,
      "postcss": true,
      "minified": true
    },
    "usingComponents": true,
    "permission": {
      "scope.userLocation": {
        "desc": "获取位置用于推荐附近出发地"
      }
    },
    "requiredPrivateInfos": [
      "chooseAddress",
      "getPhoneNumber"
    ],
    "optimization": {
      "subPackages": true
    },
    "navigateToMiniProgramAppIdList": [],
    "plugins": {}
  },
  "mp-alipay": {
    "appid": "",
    "usingComponents": true
  },
  "h5": {
    "devServer": {
      "port": 3001,
      "proxy": {
        "/api": {
          "target": "http://localhost:8080",
          "changeOrigin": true
        }
      }
    }
  }
}
