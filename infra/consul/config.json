{
  "datacenter": "dc1",
  "data_dir": "./data/consul",
  "log_level": "INFO",
  "node_name": "travel-booking-consul",
  "server": true,
  "bootstrap_expect": 1,
  "ui_config": {
    "enabled": true
  },
  "addresses": {
    "http": "0.0.0.0"
  },
  "ports": {
    "http": 8500,
    "dns": 8600,
    "grpc": 8502,
    "serf_lan": 8301,
    "serf_wan": 8302,
    "server": 8300
  },
  "connect": {
    "enabled": true
  },
  "acl": {
    "enabled": false,
    "default_policy": "allow"
  },
  "telemetry": {
    "prometheus_retention_time": "60s",
    "disable_hostname": true
  }
}
