{
  "annotations": {
    "list": []
  },
  "description": "Infrastructure metrics: CPU, Memory, Disk, Network per node (PRD §10.4.2)",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "CPU Usage",
      "description": "Per-CPU core utilization. Alert: >80% for 10min (P2)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisLabel": "%",
            "drawStyle": "line",
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "lineWidth": 2,
            "scaleDistribution": { "type": "linear" },
            "thresholdsStyle": { "mode": "line+area" }
          },
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "orange", "value": 80 },
              { "color": "red", "value": 90 }
            ]
          },
          "unit": "percent"
        }
      },
      "targets": [
        {
          "expr": "100 - (avg by(instance) (rate(windows_cpu_time_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Memory Usage",
      "description": "Used memory percentage. Alert: >85% for 10min (P2)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "%",
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2,
            "thresholdsStyle": { "mode": "line+area" }
          },
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "orange", "value": 85 },
              { "color": "red", "value": 95 }
            ]
          },
          "unit": "percent"
        }
      },
      "targets": [
        {
          "expr": "(1 - (windows_memory_available_bytes / windows_os_physical_memory_bytes)) * 100",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Disk Usage",
      "description": "Disk utilization by volume. Alert: >80% (P2)",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "orange", "value": 80 },
              { "color": "red", "value": 90 }
            ]
          },
          "unit": "percent"
        }
      },
      "targets": [
        {
          "expr": "(1 - (windows_logical_disk_free_bytes / windows_logical_disk_size_bytes)) * 100",
          "legendFormat": "{{volume}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Network I/O",
      "description": "Network bytes sent/received per interface",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2
          },
          "unit": "Bps"
        }
      },
      "targets": [
        {
          "expr": "rate(windows_net_bytes_received_total[5m])",
          "legendFormat": "recv {{nic}}",
          "refId": "A"
        },
        {
          "expr": "rate(windows_net_bytes_sent_total[5m])",
          "legendFormat": "sent {{nic}}",
          "refId": "B"
        }
      ]
    },
    {
      "title": "System Uptime",
      "description": "Time since last boot",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 3600 },
              { "color": "green", "value": 86400 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "windows_system_system_up_time",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "CPU Cores",
      "description": "Number of logical CPU cores",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 6, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "count(windows_cpu_time_total{mode=\"idle\"}) by (instance)",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Total Memory",
      "description": "Physical memory installed",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 9, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "windows_os_physical_memory_bytes",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Disk Read/Write IOPS",
      "description": "Disk operations per second",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2
          },
          "unit": "ops"
        }
      },
      "targets": [
        {
          "expr": "rate(windows_logical_disk_reads_total[5m])",
          "legendFormat": "read {{volume}}",
          "refId": "A"
        },
        {
          "expr": "rate(windows_logical_disk_writes_total[5m])",
          "legendFormat": "write {{volume}}",
          "refId": "B"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["infrastructure", "windows", "travel-booking"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "Asia/Shanghai",
  "title": "Infrastructure - Travel Booking",
  "uid": "travel-infra",
  "version": 1
}
