{
  "annotations": {
    "list": []
  },
  "description": "Application metrics: QPS, P99 latency, Error rate, Goroutine count (PRD §10.4.2 RED method)",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Request Rate (QPS)",
      "description": "Requests per second by method and path. Alert: <50% baseline for 5min (P1)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2
          },
          "unit": "reqps"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(travel_http_requests_total[5m])) by (method)",
          "legendFormat": "{{method}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "P99 Response Time",
      "description": "99th percentile response latency. Alert: >1s for 5min (P1)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "s"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(travel_http_request_duration_seconds_bucket[5m])) by (le, path))",
          "legendFormat": "p99 {{path}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(travel_http_request_duration_seconds_bucket[5m])) by (le, path))",
          "legendFormat": "p95 {{path}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(travel_http_request_duration_seconds_bucket[5m])) by (le, path))",
          "legendFormat": "p50 {{path}}",
          "refId": "C"
        }
      ]
    },
    {
      "title": "Error Rate (5xx)",
      "description": "5xx error rate as percentage of total requests. Alert: >1% for 5min (P1)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2,
            "thresholdsStyle": { "mode": "line+area" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "percentunit"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(travel_http_request_errors_total[5m])) / sum(rate(travel_http_requests_total[5m]))",
          "legendFormat": "5xx Error Rate",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Request Duration Heatmap",
      "description": "Distribution of request latencies",
      "type": "heatmap",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "calculate": false,
        "yAxis": { "unit": "s" },
        "color": { "scheme": "Oranges" },
        "cellGap": 1
      },
      "targets": [
        {
          "expr": "sum(increase(travel_http_request_duration_seconds_bucket[5m])) by (le)",
          "legendFormat": "{{le}}",
          "format": "heatmap",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Requests by Endpoint",
      "description": "Request count per API endpoint",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "left" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "custom.align", "value": "right" },
              { "id": "unit", "value": "reqps" }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "topk(20, sum(rate(travel_http_requests_total[5m])) by (path, method))",
          "legendFormat": "{{method}} {{path}}",
          "instant": true,
          "refId": "A",
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "path": "Endpoint",
              "method": "Method",
              "Value": "QPS"
            }
          }
        }
      ]
    },
    {
      "title": "Response Time by Endpoint",
      "description": "Average response time per API endpoint",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "left" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "custom.align", "value": "right" },
              { "id": "unit", "value": "s" }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "topk(20, sum(rate(travel_http_request_duration_seconds_sum[5m])) by (path, method) / sum(rate(travel_http_request_duration_seconds_count[5m])) by (path, method))",
          "legendFormat": "{{method}} {{path}}",
          "instant": true,
          "refId": "A",
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "path": "Endpoint",
              "method": "Method",
              "Value": "Avg Latency"
            }
          }
        }
      ]
    },
    {
      "title": "HTTP Status Codes",
      "description": "Distribution of HTTP response status codes",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "legend": { "displayMode": "table", "placement": "right" },
        "pieType": "donut"
      },
      "targets": [
        {
          "expr": "sum(increase(travel_http_requests_total[1h])) by (status)",
          "legendFormat": "{{status}}",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "title": "Active Database Connections",
      "description": "Current active DB connections. Alert: >80% of max (P1)",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "orange", "value": 80 },
              { "color": "red", "value": 90 }
            ]
          },
          "unit": "percent"
        }
      },
      "targets": [
        {
          "expr": "travel_active_connections",
          "legendFormat": "Active Connections",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["application", "api", "travel-booking"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "Asia/Shanghai",
  "title": "Application - Travel Booking API",
  "uid": "travel-app",
  "version": 1
}
